{
  "version": 2,
  "builds": [
    {
      "src": "public/images/livres/**",
      "use": "@vercel/static"
    },
    {
      "src": "public/images/editions/**",
      "use": "@vercel/static"
    },
    {
      "src": "server-local.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "db/**",
          "assets/*.js",
          "assets/*.css",
          "assets/*.svg",
          "assets/*.png",
          "assets/pdfs/**",
          "assets/audios/**",
          "assets/images/**",
          "public/*.html",
          "public/*.json",
          "public/*.js",
          "public/*.png",
          "public/*.ico",
          "public/*.svg",
          "public/pdfs/**",
          "public/videos/avatar/**",
          "public/videos/veo31/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/images/livres/(.*)",
      "dest": "/public/images/livres/$1",
      "headers": { "Cache-Control": "public, max-age=2592000, immutable" }
    },
    {
      "src": "/images/editions/(.*)",
      "dest": "/public/images/editions/$1",
      "headers": { "Cache-Control": "public, max-age=2592000, immutable" }
    },
    {
      "src": "/audios/(.*)",
      "dest": "server-local.js",
      "headers": { "Cache-Control": "public, max-age=2592000, immutable" }
    },
    {
      "src": "/images/(.*)",
      "dest": "server-local.js",
      "headers": { "Cache-Control": "public, max-age=2592000, immutable" }
    },
    {
      "src": "/pdfs/(.*)",
      "dest": "server-local.js",
      "headers": { "Cache-Control": "public, max-age=2592000, immutable" }
    },
    {
      "src": "/(.*\\.css)",
      "dest": "server-local.js",
      "headers": { "Cache-Control": "public, max-age=604800" }
    },
    {
      "src": "/(.*\\.js)",
      "dest": "server-local.js",
      "headers": { "Cache-Control": "public, max-age=604800" }
    },
    {
      "src": "/(.*)",
      "dest": "server-local.js"
    }
  ]
}
